{
  "name": "genomics-qc-site-demo",
  "version": "1.0.0",
  "description": "A demo Genomics QC site, built with ClojureScript + AG-Grid",
  "main": "main.js",
  "scripts": {
    "postinstall": "cp node_modules/ag-grid-community/styles/ag-grid.css resources/public/css/ag-grid.css && cp node_modules/ag-grid-community/styles/ag-theme-balham.css resources/public/css/ag-theme-balham.css",
    "dev": "clojure -M:dev -m shadow.cljs.devtools.cli watch app",
    "release": "clojure -M:dev -m shadow.cljs.devtools.cli release app",
    "clean": "rm -rf public/js",
    "test": "clojure -M:dev:test -m shadow.cljs.devtools.cli compile test && node target/test/test.js",
    "test:watch": "clojure -M:dev:test -m shadow.cljs.devtools.cli watch test"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "shadow-cljs": "^3.4.11"
  },
  "dependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "ag-grid-community": "^35.0.1",
    "ag-grid-react": "^35.0.1"
  }
}
